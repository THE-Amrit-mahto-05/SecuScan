{
  "id": "cloud_storage_auditor",
  "name": "S3 / Blob Auditor",
  "version": "1.0.0",
  "description": "Find misconfigured S3 buckets and exposed cloud storage.",
  "long_description": "Find misconfigured S3 buckets and exposed cloud storage.",
  "category": "vulnerability",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "🛠️",
  "engine": {
    "type": "cli",
    "binary": "uncover"
  },
  "command_template": [
    "uncover",
    "-q",
    "{query}",
    "-limit",
    "{limit:100}",
    "-silent"
  ],
  "fields": [
    {
      "id": "query",
      "label": "Search Query",
      "type": "string",
      "required": true,
      "placeholder": "s3.amazonaws.com org:example"
    },
    {
      "id": "limit",
      "label": "Result Limit",
      "type": "integer",
      "required": false,
      "default": 100
    }
  ],
  "presets": {
    "default": {
      "limit": 100
    }
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "safe",
    "requires_consent": true,
    "consent_message": "Cloud storage auditing should be scoped to authorized assets.",
    "rate_limit": {
      "max_per_hour": 20,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "uncover"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "d378d7c8b7fb7375a18ca24b46ef68b8e8021739cfb268c9e9581e6cc7a04f2c"
}